<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://use.hugeicons.com/font/icons.css" />
    <title>Home Page</title>
</head>
<body>
   <div class="w-full bg-[#003b95] pb-32 flex justify-center items-center">
    <div class="w-[75%] flex flex-col gap-[6rem] ">
       <%- include("./partials/navbar.ejs")%>
       <div>
         <h1 class="text-5xl text-center text-white font-bold">Where to next, <%= user.firstName %>? </h1>
         <p class="text-3xl text-center text-white mt-3">Find exclusive flights for every corner of the world!</p>
       </div>
    </div>
   </div>

   <div class="w-full bg-white flex justify-center pb-24">
    <div class="w-[75%] -mt-16 relative z-10">
        <div class="bg-[#0b1c3a] rounded-2xl p-6 shadow-xl">
            <div class="flex flex-col lg:flex-row items-stretch bg-white rounded-xl overflow-hidden">
                <div class="flex-1 px-5 py-3 border-b lg:border-b-0 lg:border-r border-gray-200">
                    <label class="block text-xs font-semibold text-black">From</label>
                    <input value="Bahrain (BAH)" class="w-full text-black font-medium outline-none bg-transparent">
                </div>
                <div class="flex-1 px-5 py-3 border-b lg:border-b-0 lg:border-r border-gray-200">
                    <label class="block text-xs font-semibold text-black">To</label>
                    <input placeholder="Country, city or airport"
                        class="w-full text-black placeholder:text-black/40 outline-none bg-transparent">
                </div>
                <div class="flex-1 px-5 py-3 border-b lg:border-b-0 lg:border-r border-gray-200">
                    <label class="block text-xs font-semibold text-black">Depart</label>
                    <input placeholder="Add date"
                        class="w-full text-black placeholder:text-black/40 outline-none bg-transparent">
                </div>
                <div class="flex-1 px-5 py-3 border-b lg:border-b-0 lg:border-r border-gray-200">
                    <label class="block text-xs font-semibold text-black">Return</label>
                    <input placeholder="Add date"
                        class="w-full text-black placeholder:text-black/40 outline-none bg-transparent">
                </div>
                <button
                    class="w-full lg:w-auto shrink-0 bg-[#4d53ff] hover:bg-[#3d43e0] transition-colors text-white font-semibold px-10 py-4 lg:py-0 flex items-center justify-center gap-2">
                    Search
                </button>
            </div>
        </div>

        <%
            const fmt = (iso) => new Date(iso).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });
            const fmtTime = (iso) => new Date(iso).toLocaleString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false });
            const fmtDuration = (mins) => {
                if (!mins) return "";
                const h = Math.floor(mins / 60);
                const m = mins % 60;
                return h + "h" + (m ? " " + m + "m" : "");
            };
            const stopsLabel = (stops) => stops === 0 ? "Nonstop" : stops + " stop" + (stops > 1 ? "s" : "");
            const CLASS_COLUMNS = [
                { key: "economyPrice", type: "economy", label: "Economy", bg: "bg-blue-50/60" },
                { key: "businessPrice", type: "business", label: "Business", bg: "bg-amber-50/60" },
                { key: "firstPrice", type: "first", label: "First", bg: "bg-purple-50/60" },
            ];
        %>
            <div class="mt-12">
                <h2 class="text-2xl font-bold text-black">Available Flights</h2>

                <% if (flights.length===0) { %>
                    <div class="mt-6 p-10 rounded-2xl bg-gray-50 flex flex-col items-center text-center gap-2">
                        <i class="hgi text-4xl text-black/30 hgi-stroke hgi-rounded hgi-airplane-01"></i>
                        <p class="font-medium text-black/60">No flights available right now</p>
                    </div>
                    <% } else { %>
                        <div class="mt-6 rounded-2xl border border-gray-200 overflow-hidden">
                            <div
                                class="hidden md:grid grid-cols-[2fr_1fr_1fr_1fr] bg-gray-50 border-b border-gray-200">
                                <div class="p-4 font-bold text-lg text-black">Outbound flights</div>
                                <% CLASS_COLUMNS.forEach(col=> { %>
                                    <div
                                        class="p-4 text-center font-bold text-lg text-black border-l border-gray-200">
                                        <%= col.label %>
                                    </div>
                                    <% }); %>
                            </div>

                            <% flights.forEach(flight=> { %>
                                <div
                                    class="grid grid-cols-1 md:grid-cols-[2fr_1fr_1fr_1fr] border-b border-gray-100 last:border-b-0">
                                    <div class="p-5">
                                     <div class="flex items-center gap-2">
                                           <img width="70" height="70" src="<%= flight.airlineId.logo  %>" />
                                        <span class="font-medium">
                                            <%= flight.airlineId ? flight.airlineId.name : "Unknown Airline" %>
                                                <% if (flight.planeTypeId) { %>
                                                    <%= flight.planeTypeId.code %>
                                                        <% } %>
                                        </span>
                                     </div>
                                        <div class="flex items-center gap-3">
                                            <div>
                                                <p class="text-lg font-bold text-black">
                                                    <%= fmtTime(flight.departureTime) %>
                                                </p>
                                                <p class="text-xs text-black/50">
                                                    <%= flight.origin %>
                                                </p>
                                            </div>
                                            <div class="flex-1 flex flex-col items-center px-1">
                                                <div class="w-full flex items-center gap-1">
                                                    <span class="w-1.5 h-1.5 rounded-full bg-gray-300 shrink-0"></span>
                                                    <span class="flex-1 border-t border-dashed border-gray-300"></span>
                                                    <i class="hgi hgi-stroke hgi-rounded hgi-airplane-01 text-black/40 text-sm"></i>
                                                    <span class="flex-1 border-t border-dashed border-gray-300"></span>
                                                    <span class="w-1.5 h-1.5 rounded-full bg-gray-300 shrink-0"></span>
                                                </div>
                                                <p class="text-xs text-black/50 mt-1 whitespace-nowrap">
                                                    <%= stopsLabel(flight.stops || 0) %>
                                                        <% if (flight.duration) { %>
                                                            &middot; <%= fmtDuration(flight.duration) %>
                                                                <% } %>
                                                </p>
                                            </div>
                                            <div>
                                                <p class="text-lg font-bold text-black">
                                                    <%= fmtTime(flight.arrivalTime) %>
                                                </p>
                                                <p class="text-xs text-black/50">
                                                    <%= flight.destination %>
                                                </p>
                                            </div>
                                        </div>
                                        <p class="text-xs text-black/40 mt-3">
                                            <%= fmt(flight.departureTime) %> &middot; <%= flight.flightNumber %>
                                        </p>
                                    </div>

                                    <% CLASS_COLUMNS.forEach(col=> { %>
                                        <div
                                            class="flex md:flex-col items-center justify-between md:justify-center gap-2 p-5 border-t md:border-t-0 md:border-l border-gray-100 <%= col.bg %>">
                                            <span class="md:hidden text-sm font-medium text-black/60">
                                                <%= col.label %>
                                            </span>
                                            <% if (flight[col.key]) { %>
                                                <a href="/booking/<%= col.type %>/<%= flight._id %>"
                                                    class="flex md:flex-col items-center gap-3 md:gap-0 hover:opacity-80 transition-opacity">
                                                    <div class="text-center md:text-left">
                                                        <p class="text-xs text-black/50">From <span
                                                                class="font-semibold text-black">BHD</span></p>
                                                        <p class="text-xl font-bold text-black">
                                                            <%= flight[col.key] %>
                                                        </p>
                                                    </div>
                                                </a>
                                                <% } else { %>
                                                    <p class="text-sm text-black/40">Not available</p>
                                                    <% } %>
                                        </div>
                                        <% }); %>
                                </div>
                                <% }); %>
                        </div>
                        <% } %>
            </div>
    </div>
   </div>
</body>
</html>