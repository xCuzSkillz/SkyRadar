<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://use.hugeicons.com/font/icons.css" />
    <title>Admin Page</title>
</head>

<body>
    <section class="flex flex-col md:flex-row items-start w-full">
        <aside
            class="w-full md:w-[20%] md:min-h-screen p-5 bg-[#fafafa] border-b md:border-b-0 md:border-r border-[#d3d2d2]">
            <div class="flex items-center gap-3">
                <i class="hgi text-5xl text-[#4d53ff] hgi-stroke hgi-rounded hgi-airplane-01"></i>
                <h3 class="text-2xl font-bold">SkyRadar Admin</h3>
            </div>
            <div class="flex flex-col gap-4 mt-10">
                <div class="flex flex-col">
                    <p class="uppercase text-black/50 font-medium">Airlines</p>
                    <a href="/admin"
                        class="mt-3 bg-white p-3 py-2 font-medium rounded-xl border-2 border-gray-200/80 shadow-sm flex items-center gap-2">
                        <i class="hgi hgi-stroke hgi-rounded hgi-home-01 text-lg"></i> Overview
                    </a>
                    <a href="admin/airlines-management"
                        class="mt-3  p-3 py-2 font-medium rounded-xl border-2 border-transparent flex items-center gap-2">
                        <i class="hgi hgi-stroke hgi-rounded hgi-airplane-02 text-lg"></i> Airlines Management
                    </a>
                </div>
                <div class="flex flex-col">
                    <p class="uppercase text-black/50 font-medium">Flights</p>
                    <a href="/admin/flights-management"
                        class="mt-3 p-3 py-2 font-medium rounded-xl border-2 border-transparent flex items-center gap-2">
                        <i class="hgi hgi-stroke hgi-rounded hgi-airplane-take-off-01 text-lg"></i> Flights
                        Management
                    </a>
                </div>
                <div class="flex flex-col">
                    <p class="uppercase text-black/50 font-medium">Promo Codes</p>
                    <a href="/admin/promocode-management"
                        class="mt-3 p-3 py-2 font-medium rounded-xl border-2 border-transparent flex items-center gap-2">
                        <i class="hgi hgi-stroke hgi-rounded hgi-coupon-01 text-lg"></i> Promo Codes
                    </a>
                </div>
                <div class="flex flex-col">
                    <p class="uppercase text-black/50 font-medium">Plane Types</p>
                    <a href="/admin/plane-types-management"
                        class="mt-3 p-3 py-2 font-medium rounded-xl border-2 border-transparent flex items-center gap-2">
                        <i class="hgi hgi-stroke hgi-rounded hgi-plane text-lg"></i> Plane Types
                    </a>
                </div>
        </aside>
        <div class="min-h-screen w-full md:w-[85%]">
            <div class="flex flex-wrap gap-3 justify-between items-center border-b border-[#d3d2d2] p-6">
                <div class="flex items-center gap-3">
                    <span class="text-black/50 font-medium">Dashboard</span>
                    <span class="text-black/50 font-medium">/</span>
                    <span class="font-medium">Overview</span>

                </div>
                <div class="rounded-full p-2 bg-[#4d53ff] text-white">
                    <%= user.firstName.trim().charAt(0) %><%= user.lastName.trim().charAt(0) %>
                </div>
            </div>
            <div class="p-4 sm:p-6">
                <div class="flex flex-col gap-2">
                    <h2 class="text-xl font-medium">Hello, <%= user.firstName %>
                            <%= user.lastName%> Welcome Back 👋</h2>
                    <p class="text-[17px] text-black/70">Here's the latest updates overall flights bookings</p>
                </div>
            </div>
        </div>
    </section>
</body>

</html>