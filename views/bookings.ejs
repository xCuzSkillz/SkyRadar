<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://use.hugeicons.com/font/icons.css" />
    <title>My Bookings</title>
</head>
<body>
<div class="w-full bg-[#003b95] pb-32 flex justify-center items-center">
    <div class="w-[75%] flex flex-col gap-[3rem] ">
       <%- include("./partials/navbar.ejs")%>
       <div>
         <h1 class="text-4xl text-center text-white font-bold">My Bookings</h1>
       </div>
    </div>
   </div>

   <div class="w-full bg-white flex justify-center pb-24">
    <div class="w-[75%] -mt-16 relative z-10">
        <%
            const fmt = (iso) => new Date(iso).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit', hour12: false });
            const CLASS_LABELS = { economy: "Economy", business: "Business", first: "First" };
            const STATUS_STYLES = {
                pending: "bg-yellow-100 text-yellow-700",
                confirmed: "bg-green-100 text-green-700",
                cancelled: "bg-red-100 text-red-700",
                completed: "bg-gray-100 text-gray-700",
                refunded: "bg-blue-100 text-blue-700",
            };
        %>
            <% if (bookings.length===0) { %>
                <div
                    class="bg-white rounded-2xl shadow-xl border border-gray-200 p-10 flex flex-col items-center text-center gap-2">
                    <i class="hgi text-4xl text-black/30 hgi-stroke hgi-rounded hgi-airplane-01"></i>
                    <p class="font-medium text-black/60">No bookings yet</p>
                    <a href="/" class="mt-2 text-[#4d53ff] font-medium hover:underline">Browse flights</a>
                </div>
                <% } else { %>
                    <div class="flex flex-col gap-4">
                        <% bookings.forEach(booking=> { %>
                            <% const flight=booking.flightId; %>
                                <% const passengers=passengersByBooking[booking._id.toString()] || []; %>
                                    <div class="bg-white rounded-2xl shadow-xl border border-gray-200 p-6">
                                        <div class="flex items-center justify-between flex-wrap gap-3">
                                            <div class="flex items-center gap-3">
                                                <% if (flight && flight.airlineId && flight.airlineId.logo) { %>
                                                    <img src="<%= flight.airlineId.logo %>"
                                                        class="w-10 h-10 rounded-full object-cover ring-1 ring-gray-200" />
                                                    <% } %>
                                                        <div>
                                                            <p class="font-semibold text-black">
                                                                <%= flight && flight.airlineId ? flight.airlineId.name
                                                                    : "Unknown Airline" %>
                                                            </p>
                                                            <p class="text-xs text-black/50">
                                                                <%= flight ? flight.flightNumber : "" %>
                                                            </p>
                                                        </div>
                                            </div>
                                            <span
                                                class="inline-block rounded-full text-xs font-semibold px-3 py-1 capitalize <%= STATUS_STYLES[booking.status] || 'bg-gray-100 text-gray-700' %>">
                                                <%= booking.status %>
                                            </span>
                                        </div>

                                        <% if (flight) { %>
                                            <div class="mt-4 flex items-center gap-4 text-black">
                                                <div>
                                                    <p class="font-semibold">
                                                        <%= fmt(flight.departureTime) %>
                                                    </p>
                                                    <p class="text-xs text-black/50">
                                                        <%= flight.origin %>
                                                    </p>
                                                </div>
                                                <i class="hgi hgi-stroke hgi-rounded hgi-arrow-right-01 text-black/30"></i>
                                                <div>
                                                    <p class="font-semibold">
                                                        <%= fmt(flight.arrivalTime) %>
                                                    </p>
                                                    <p class="text-xs text-black/50">
                                                        <%= flight.destination %>
                                                    </p>
                                                </div>
                                            </div>
                                            <% } %>

                                                <div
                                                    class="mt-4 pt-4 border-t border-gray-100 flex items-center justify-between flex-wrap gap-3">
                                                    <div>
                                                        <span
                                                            class="inline-block rounded-full bg-[#e9e8ff] text-[#4d53ff] text-xs font-semibold px-3 py-1">
                                                            <%= CLASS_LABELS[booking.tripType] || booking.tripType %>
                                                        </span>
                                                        <p class="text-sm text-black/50 mt-2">
                                                            <%= passengers.map(p=> p.fullName).join(", " ) || "No passenger info" %>
                                                        </p>
                                                    </div>
                                                    <p class="text-xl font-bold text-black">BHD <%= booking.totalPrice
                                                        %>
                                                    </p>
                                                </div>
                                    </div>
                                    <% }); %>
                    </div>
                    <% } %>
    </div>
   </div>
</body>
</html>
