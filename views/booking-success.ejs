<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://use.hugeicons.com/font/icons.css" />
    <title>Payment Successful</title>
</head>
<body>
<div class="w-full bg-[#003b95] pb-32 flex justify-center items-center">
    <div class="w-[75%] flex flex-col gap-[3rem] ">
       <%- include("./partials/navbar.ejs")%>
    </div>
   </div>

   <div class="w-full bg-white flex justify-center pb-24">
    <div class="w-[75%] -mt-16 relative z-10">
        <%
            const flight = booking.flightId;
            const fmt = (iso) => new Date(iso).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit', hour12: false });
            const CLASS_LABELS = { economy: "Economy", business: "Business", first: "First" };
        %>
        <div class="bg-white rounded-2xl shadow-xl border border-gray-200 p-6 sm:p-10 flex flex-col items-center text-center">
            <i class="hgi text-6xl text-green-500 hgi-stroke hgi-rounded hgi-checkmark-circle-02"></i>
            <h1 class="text-3xl font-bold text-black mt-4">Payment Successful!</h1>
            <p class="text-black/60 mt-2">Your booking is confirmed. A confirmation has been added to your bookings.</p>

            <div class="w-full max-w-md mt-8 pt-6 border-t border-gray-200 text-left">
                <% if (flight) { %>
                    <div class="flex items-center gap-3">
                        <% if (flight.airlineId && flight.airlineId.logo) { %>
                            <img src="<%= flight.airlineId.logo %>"
                                class="w-10 h-10 rounded-full object-cover ring-1 ring-gray-200" />
                            <% } %>
                                <div>
                                    <p class="font-semibold text-black">
                                        <%= flight.airlineId ? flight.airlineId.name : "Unknown Airline" %>
                                            <%= flight.flightNumber %>
                                    </p>
                                    <p class="text-sm text-black/50">
                                        <%= flight.origin %> &rarr; <%= flight.destination %> &middot; <%=
                                            fmt(flight.departureTime) %>
                                    </p>
                                </div>
                    </div>
                    <% } %>
                        <div class="mt-4 flex items-center justify-between">
                            <span
                                class="inline-block rounded-full bg-[#e9e8ff] text-[#4d53ff] text-xs font-semibold px-3 py-1">
                                <%= CLASS_LABELS[booking.tripType] || booking.tripType %>
                            </span>
                            <p class="text-xl font-bold text-black">BHD <%= booking.totalPrice %>
                            </p>
                        </div>
            </div>

            <div class="flex items-center gap-3 mt-8">
                <a href="/bookings"
                    class="bg-[#4d53ff] hover:bg-[#3d43e0] transition-colors text-white font-semibold px-8 py-3.5 rounded-lg">
                    View My Bookings
                </a>
                <a href="/"
                    class="border border-gray-300 hover:bg-gray-50 transition-colors text-black font-semibold px-8 py-3.5 rounded-lg">
                    Back to Home
                </a>
            </div>
        </div>
    </div>
   </div>
</body>
</html>
